rules_version = '2';

// ─── REGRAS FIRESTORE — Tracking V4 ──────────────────────────────────────────
// Publicar no console Firebase (Firestore Database → Regras) ou via CLI:
//   firebase deploy --only firestore:rules
//
// Modelo atual:
//  - Leitura/escrita geral: apenas usuários autenticados (equipe interna).
//  - Ingestão de eventos (/api/track) roda no servidor Next.js com o SDK client
//    (sem sessão de usuário); por isso eventos/identidades/conversoes aceitam
//    create sem auth, e o doc do cliente aceita LEITURA pública — o endpoint
//    precisa ler trackingKey para validar a requisição. trackingKey não é
//    segredo: já vai embutido em texto puro no <script> do site do cliente
//    (mesmo modelo do GA Measurement ID / write key do Segment).
//    HARDENING FUTURO: mover a ingestão para firebase-admin (service account)
//    e trocar os blocos "allow create/read: if true" por "if false".

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── PARTNERS (novo modelo — convive com /clientes durante a migração) ────
    // Controle de acesso real por parceiro: só quem está em members/ (ou é
    // superadmin via config/superadmins) lê/escreve. "admin" lê+escreve tudo
    // dentro do parceiro; "viewer" só lê. Leitura pública do doc raiz e create
    // público em eventos/conversoes seguem o mesmo motivo de hoje (ingestão via
    // /api/track e webhook, sem sessão de usuário).
    function emailLogado() {
      return request.auth.token.email.lower()
    }
    function ehSuperAdmin() {
      return request.auth != null &&
        emailLogado() in get(/databases/$(database)/documents/config/superadmins).data.emails
    }
    function membro(partnerId) {
      return get(/databases/$(database)/documents/partners/$(partnerId)/members/$(emailLogado()))
    }
    function ehMembro(partnerId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/partners/$(partnerId)/members/$(emailLogado()))
    }
    function ehMembroAdmin(partnerId) {
      return ehMembro(partnerId) && membro(partnerId).data.role == 'admin'
    }
    function temAcesso(partnerId) {
      return ehSuperAdmin() || ehMembro(partnerId)
    }
    function temAcessoAdmin(partnerId) {
      return ehSuperAdmin() || ehMembroAdmin(partnerId)
    }

    match /partners/{partnerId} {
      allow read: if true;             // trackingKey precisa ser lido por /api/track (não autenticado)
      allow write: if temAcessoAdmin(partnerId);

      match /members/{memberEmail} {
        allow read, write: if temAcessoAdmin(partnerId);
      }

      match /eventos/{eventoId} {
        allow read: if temAcesso(partnerId);
        allow create: if true;          // ingestão via /api/track
        allow update, delete: if temAcessoAdmin(partnerId);
      }

      match /identidades/{visitorId} {
        // LEITURA PÚBLICA — mesmo motivo/risco aceito documentado no bloco
        // /clientes abaixo (resolução de identidade em /api/track sem sessão).
        allow read: if true;
        allow create, update: if true;
        allow delete: if temAcessoAdmin(partnerId);
      }

      match /conversoes/{conversaoId} {
        allow read: if temAcesso(partnerId);
        allow create: if true;          // fila montada na ingestão
        allow update, delete: if temAcessoAdmin(partnerId);
      }

      match /{subcolecao}/{docId} {
        allow read: if temAcesso(partnerId);
        allow write: if temAcessoAdmin(partnerId);
      }
    }

    // Doc único e global — lista de e-mails com bypass de superadmin.
    // Sem "allow read" pra client SDK: só a própria engine de regras (get()
    // acima) precisa enxergar esse doc; edição é manual via Console.
    match /config/{doc} {
      allow read, write: if false;
    }

    match /clientes/{clienteId} {
      allow read: if true;             // trackingKey precisa ser lido por /api/track (não autenticado)
      allow write: if request.auth != null;

      match /eventos/{eventoId} {
        allow read: if request.auth != null;
        allow create: if true;          // ingestão via /api/track
        allow update, delete: if request.auth != null;
      }

      match /identidades/{visitorId} {
        // LEITURA PÚBLICA — necessária: a resolução de identidade em /api/track
        // consulta por v4id/email/telefone/fbp/gclid para fundir perfis, sem
        // sessão de usuário (SDK client, sem service account). Isso expõe PII
        // (email, telefone, cidade, IP) a quem tiver a config pública do
        // Firebase — já embutida no JS do site, mas amplia a superfície de
        // consulta. HARDENING: mover a ingestão para firebase-admin
        // (service account) elimina essa exposição sem downtime.
        allow read: if true;
        allow create, update: if true;  // resolução de identidade via /api/track
        allow delete: if request.auth != null;
      }

      match /conversoes/{conversaoId} {
        allow read: if request.auth != null;
        allow create: if true;          // fila montada na ingestão
        allow update, delete: if request.auth != null;
      }

      match /{subcolecao}/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // users/{email} — token Meta (OAuth) do gestor, chave = e-mail em lowercase.
    // Escrita só via firebase-admin (rotas /api/meta/*), por isso não há
    // "allow write" aqui: o SDK client nunca grava o access_token diretamente.
    // Leitura liberada apenas pro próprio dono, para a UI mostrar status de
    // conexão (o token fica visível ao dono, que já o possui via OAuth).
    match /users/{email} {
      allow read: if request.auth != null && request.auth.token.email.lower() == email;
    }
  }
}
