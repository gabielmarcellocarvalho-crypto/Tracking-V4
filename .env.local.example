# ─── Firebase (client SDK) ───────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Meta CAPI / OAuth ────────────────────────────────────────────────────────
# App criado em developers.facebook.com com o produto "Facebook Login"
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=

# ─── Firebase Admin (service account) ───────────────────────────────────────
# JSON completo da service account (Firebase Console → Configurações do
# projeto → Contas de serviço → Gerar nova chave privada), em uma única
# linha (string JSON). Usado só nas rotas server (lib/firebase-admin.ts).
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Agente IA (Gemini) ──────────────────────────────────────────────────────
# Key criada em aistudio.google.com/apikey. Usada só na rota server
# /api/agent (nunca exposta ao client).
GEMINI_API_KEY=

# ─── Cron (reenvio de conversões) ───────────────────────────────────────────
# Gerado automaticamente pela Vercel ao criar o cron job (Project Settings →
# Cron Jobs) — protege /api/cron/reenviar-conversoes contra chamadas externas.
CRON_SECRET=

# ─── Firebase Emulator (dev local) ──────────────────────────────────────────
# true = lib/firebase.ts conecta nos emuladores locais (firebase emulators:start)
# em vez do projeto real. Nunca setar isso no ambiente da Vercel.
NEXT_PUBLIC_USE_EMULATOR=
